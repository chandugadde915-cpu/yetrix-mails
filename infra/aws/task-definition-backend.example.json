{
  "family": "ownmail-backend",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "containerDefinitions": [
    {
      "name": "api",
      "image": "YOUR_AWS_ACCOUNT_ID.dkr.ecr.YOUR_REGION.amazonaws.com/ownmail-backend:latest",
      "portMappings": [
        {
          "containerPort": 4000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "PORT",
          "value": "4000"
        },
        {
          "name": "CORS_ORIGIN",
          "value": "https://www.yetrixtechnologies.com"
        },
        {
          "name": "MAILCOW_BASE_URL",
          "value": "https://mail.yetrixtechnologies.com"
        },
        {
          "name": "MAIL_DOMAIN",
          "value": "yetrixtechnologies.com"
        },
        {
          "name": "MAIL_SERVER_IP",
          "value": "56.228.11.175"
        },
        {
          "name": "MAILCOW_DKIM_SELECTOR",
          "value": "dkim"
        }
      ],
      "secrets": [
        {
          "name": "MAILCOW_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:YOUR_REGION:YOUR_ACCOUNT_ID:secret:yetrix/mailcow-api-key"
        },
        {
          "name": "ADMIN_USERNAME",
          "valueFrom": "arn:aws:secretsmanager:YOUR_REGION:YOUR_ACCOUNT_ID:secret:yetrix/admin-username"
        },
        {
          "name": "ADMIN_PASSWORD",
          "valueFrom": "arn:aws:secretsmanager:YOUR_REGION:YOUR_ACCOUNT_ID:secret:yetrix/admin-password"
        },
        {
          "name": "AUTH_SECRET",
          "valueFrom": "arn:aws:secretsmanager:YOUR_REGION:YOUR_ACCOUNT_ID:secret:yetrix/auth-secret"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/ownmail-backend",
          "awslogs-region": "YOUR_REGION",
          "awslogs-stream-prefix": "api"
        }
      }
    }
  ]
}
